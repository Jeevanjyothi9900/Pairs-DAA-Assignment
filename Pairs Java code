import java.util.*;

public class Solution {

    /**
     * Finds the number of pairs in the array that have a difference equal to k.
     * Logic: For every number 'x', we check if 'x + k' exists in our set.
     */
    public static int pairs(int k, List<Integer> arr) {
        // Step 1: Put all numbers into a HashSet. 
        // Sets allow us to check if a number exists in O(1) time.
        Set<Integer> set = new HashSet<>(arr);
        int count = 0;

        // Step 2: Iterate through the original list
        for (int num : arr) {
            // If (num + k) exists in the set, then (num + k) - num = k.
            // We've found a valid pair!
            if (set.contains(num + k)) {
                count++;
            }
        }

        return count;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        // Read n (size of array) and k (target difference)
        if (!scanner.hasNextInt()) return;
        int n = scanner.nextInt();
        int k = scanner.nextInt();

        List<Integer> arr = new ArrayList<>();
        for (int i = 0; i < n; i++) {
            arr.add(scanner.nextInt());
        }

        // Calculate and print the result
        int result = pairs(k, arr);
        System.out.println(result);

        scanner.close();
    }
}

        

